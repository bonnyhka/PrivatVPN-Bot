generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  telegramId      String         @unique
  username        String?
  firstName       String?
  lastName        String?
  avatar          String?
  role            String         @default("user")
  referralCode    String?        @unique @default(uuid())
  referredById    String?
  balance         Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  payments        Payment[]
  referralActions Referral[]     @relation("ReferrerHistory")
  wasReferredArr  Referral[]     @relation("ReferredHistory")
  routerOrders    RouterOrder[]
  routerReviews   RouterReview[]
  subscription    Subscription?
  tickets         Ticket[]
  referredBy      User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals       User[]         @relation("UserReferrals")
  pings           UserPing[]

  @@index([username])
  @@index([role, createdAt])
}

model RouterProduct {
  id          String         @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  stock       Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  specs       String?
  orders      RouterOrder[]
  reviews     RouterReview[]
}

model RouterOrder {
  id             String        @id @default(cuid())
  userId         String
  productId      String
  status         String        @default("pending")
  fullName       String
  phone          String
  address        String
  city           String
  zipCode        String?
  trackingNumber String?
  amount         Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        RouterProduct @relation(fields: [productId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model RouterReview {
  id           String        @id @default(cuid())
  productId    String
  userId       String
  rating       Int
  comment      String
  createdAt    DateTime      @default(now())
  productIdRel RouterProduct @relation(fields: [productId], references: [id])
  userIdRel    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([userId, createdAt])
}

model Subscription {
  id                    String       @id @default(cuid())
  planId                String
  status                String       @default("active")
  subscriptionUrl       String       @unique
  vlessUuid             String?
  autoRenew             Boolean      @default(false)
  expiresAt             DateTime
  trafficUsed           BigInt       @default(0)
  lastTrafficReset      DateTime     @default(now())
  isManual              Boolean      @default(false)
  isTrial               Boolean      @default(false)
  lastExpiredReminderAt DateTime?
  customBypassDomains   String?      @default("")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  userId                String       @unique
  routingMode           String?      @default("default")
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trafficLogs           TrafficLog[]

  @@index([status, expiresAt])
  @@index([planId, status])
  @@index([createdAt])
}

model PendingMessageDelete {
  id        String   @id @default(cuid())
  chatId    String
  messageId Int
  deleteAt  DateTime
  createdAt DateTime @default(now())
}

model Gift {
  id         String    @id @default(cuid())
  planId     String
  months     Int       @default(1)
  code       String    @unique
  fromId     String?
  toId       String?
  toUsername String?
  isUsed     Boolean   @default(false)
  isPreOrder Boolean   @default(false)
  createdAt  DateTime  @default(now())
  usedAt     DateTime?
}

model TrafficLog {
  id             String       @id @default(cuid())
  subscriptionId String
  bytes          BigInt
  timestamp      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([timestamp])
}

model Location {
  id                     String    @id @default(cuid())
  name                   String
  country                String
  flag                   String
  host                   String
  ping                   Int       @default(0)
  load                   Int       @default(0)
  liveConnections        Int       @default(0)
  lastLoadCheck          DateTime?
  isActive               Boolean   @default(true)
  ssPort                 Int?
  ssPassword             String?
  ssMethod               String?   @default("chacha20-ietf-poly1305")
  vlessUuid              String?
  vlessPort              Int?
  vlessNetwork           String?   @default("tcp")
  vlessTls               Boolean   @default(false)
  vlessPath              String?
  vlessHost              String?
  vlessReality           Boolean?  @default(false)
  vlessRealityPublicKey  String?
  vlessRealityShortId    String?
  vlessRealitySni        String?
  sshPass                String?
  sshUser                String?
  vlessRealityPrivateKey String?
}

model Ticket {
  id        String          @id @default(cuid())
  subject   String
  status    String          @default("open")
  priority  String          @default("normal")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TicketMessage[]

  @@index([userId, status, updatedAt])
}

model PlanConfig {
  id           String   @id
  price        Float
  features     String
  trafficLimit BigInt?
  updatedAt    DateTime @updatedAt
}

model TicketMessage {
  id        String   @id @default(cuid())
  body      String
  isAdmin   Boolean  @default(false)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  ticketId  String
  imageUrl  String?
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model UserPing {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  latency    Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([locationId, createdAt])
}

model DiscountCode {
  id               String    @id @default(cuid())
  code             String    @unique
  mode             String    @default("promo")
  delivery         String    @default("code")
  audience         String    @default("all")
  type             String    @default("percent")
  value            Float     @default(0)
  minPurchase      Float?
  usageLimit       Int?
  usageCount       Int       @default(0)
  validFrom        DateTime  @default(now())
  validTo          DateTime
  applicablePlans  String    @default("all")
  isActive         Boolean   @default(true)
  description      String?
  targetUsers      String?
  broadcastText    String?
  lastBroadcastAt  DateTime?
  createdAt        DateTime  @default(now())
  compensationDays Int?
  lastAppliedAt    DateTime?

  @@index([mode, isActive, validTo])
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String
  amount     Float
  status     String   @default("credited")
  createdAt  DateTime @default(now())
  referrer   User     @relation("ReferrerHistory", fields: [referrerId], references: [id])
  referred   User     @relation("ReferredHistory", fields: [referredId], references: [id])
}

model Payment {
  id               String   @id @default(cuid())
  userId           String
  planId           String
  months           Int      @default(1)
  amount           Float
  status           String   @default("pending")
  isGift           Boolean  @default(false)
  isPreOrder       Boolean  @default(false)
  receiverUsername String?
  externalId       String?  @unique
  promoCode        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([planId, createdAt])
}

model SecurityLog {
  id        String   @id @default(cuid())
  type      String
  ip        String
  path      String
  details   String?
  severity  String   @default("medium")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ip])
  @@index([type])
}

model ConnectionLog {
  id         String   @id @default(cuid())
  locationId String
  count      Int
  timestamp  DateTime @default(now())

  @@index([locationId])
  @@index([timestamp])
}

model ActiveSession {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  ip         String
  lastSeen   DateTime @default(now())

  @@unique([userId, locationId, ip])
  @@index([userId])
  @@index([locationId])
  @@index([lastSeen])
}
